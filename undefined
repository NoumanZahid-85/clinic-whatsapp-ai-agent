import os
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from dotenv import load_dotenv

load_dotenv()

from fastapi import FastAPI
from fastapi.responses import RedirectResponse
from pydantic import BaseModel
from ai_core.rag import get_vector_store, ingest_knowledge_base
from ai_core.agent import run_agent

app = FastAPI(title="CityCare Clinic AI Agent", version="1.0.0")


class MessageRequest(BaseModel):
    sender_id: str
    text: str


class MessageResponse(BaseModel):
    reply: str


@app.on_event("startup")
async def startup():
    try:
        get_vector_store()
    except Exception:
        print("ChromaDB not found -- ingesting knowledge base...")
        ingest_knowledge_base()


@app.get("/")
async def root():
    return RedirectResponse(url="/docs")


@app.get("/health")
async def health():
    return {"status": "ok"}


@app.post("/process-message", response_model=MessageResponse)
async def process_message(req: MessageRequest):
    reply = run_agent(req.sender_id, req.text)
    return MessageResponse(reply=reply)


if __name__ == "__main__":
    import uvicorn

    host = os.getenv("AI_SERVER_HOST", "0.0.0.0")
    port = int(os.getenv("AI_SERVER_PORT", "8000"))
    uvicorn.run(app, host=host, port=port)
