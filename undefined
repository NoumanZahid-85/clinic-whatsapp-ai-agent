import { makeWASocket, useMultiFileAuthState, DisconnectReason } from '@whiskeysockets/baileys';
import qrcode from 'qrcode-terminal';
import axios from 'axios';
import pino from 'pino';
import dotenv from 'dotenv';
import { fileURLToPath } from 'url';
import { dirname, join } from 'path';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

dotenv.config({ path: join(__dirname, '..', '.env') });

const AI_SERVER_URL = `http://${process.env.AI_SERVER_HOST || '0.0.0.0'}:${process.env.AI_SERVER_PORT || '8000'}`;
const AUTH_DIR = join(__dirname, 'auth_info');

let sock = null;
let reconnectTimer = null;

async function startBot() {
    const { state, saveCreds } = await useMultiFileAuthState(AUTH_DIR);

    const logger = pino({
        level: 'silent',
        transport: {
            target: 'pino/file',
            options: { destination: join(__dirname, 'baileys.log') }
        }
    });

    sock = makeWASocket({
        auth: state,
        printQRInTerminal: false,
        logger,
        syncFullHistory: false,
        markOnlineOnConnect: false,
    });

    sock.ev.on('creds.update', saveCreds);

    sock.ev.on('connection.update', async (update) => {
        const { connection, lastDisconnect, qr } = update;

        if (qr) {
            console.log('\n=== Scan this QR code with WhatsApp ===\n');
            qrcode.generate(qr, { small: true });
            console.log('\n=========================================\n');
        }

        if (connection === 'open') {
            console.log('✓ WhatsApp connected successfully!');
            console.log(`✓ AI Server: ${AI_SERVER_URL}`);
            console.log('✓ Ready to handle messages...\n');
        }

        if (connection === 'close') {
            const reason = lastDisconnect?.error?.output?.statusCode;
            const shouldReconnect = reason !== DisconnectReason.loggedOut;

            console.log(`✗ Disconnected (reason: ${reason || 'unknown'})`);

            if (shouldReconnect) {
                console.log('⟳ Reconnecting in 5 seconds...');
                if (reconnectTimer) clearTimeout(reconnectTimer);
                reconnectTimer = setTimeout(startBot, 5000);
            } else {
                console.log('✗ Logged out. Delete auth_info folder and restart.');
            }
        }
    });

    sock.ev.on('messages.upsert', async (msg) => {
        const messages = msg.messages;

        for (const message of messages) {
            if (!message.key || message.key.fromMe) continue;

            const text = message.message?.conversation
                || message.message?.extendedTextMessage?.text
                || '';

            if (!text.trim()) continue;

            const sender = message.key.remoteJid;
            console.log(`📩 From ${sender}: ${text}`);

            try {
                const response = await axios.post(`${AI_SERVER_URL}/process-message`, {
                    sender_id: sender,
                    text: text
                }, { timeout: 60000 });

                const reply = response.data.reply;

                await sock.sendMessage(sender, { text: reply });
                console.log(`📤 To ${sender}: ${reply.substring(0, 100)}...`);

            } catch (err) {
                console.error(`✗ Error processing message from ${sender}:`, err.message);

                if (err.code === 'ECONNREFUSED') {
                    await sock.sendMessage(sender, {
                        text: '⚠ Sorry, the AI server is not running. Please start it and try again.'
                    });
                } else {
                    await sock.sendMessage(sender, {
                        text: '⚠ Sorry, I encountered an error processing your message. Please try again.'
                    });
                }
            }
        }
    });

    return sock;
}

process.on('SIGINT', async () => {
    console.log('\nShutting down...');
    if (reconnectTimer) clearTimeout(reconnectTimer);
    if (sock) sock.ws.close();
    process.exit(0);
});

console.log('Starting CityCare Clinic WhatsApp Bot...');
startBot().catch(err => {
    console.error('Fatal error:', err);
    process.exit(1);
});
